# ===========================================
# AGENTE ARIBA ENTERPRISE AI — Environment
# ===========================================

# App
NODE_ENV=development
APP_NAME=Agente Ariba Enterprise AI
APP_VERSION=1.0.0

# Backend
BACKEND_PORT=3001
BACKEND_URL=http://localhost:3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_APP_NAME=Agente Ariba Enterprise AI

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ariba_agent
POSTGRES_USER=ariba
POSTGRES_PASSWORD=ariba_secure_pass

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_pass
REDIS_TTL=3600

# RabbitMQ
RABBITMQ_URL=amqp://ariba:rabbitmq_secure_pass@localhost:5672
RABBITMQ_USER=ariba
RABBITMQ_PASSWORD=rabbitmq_secure_pass

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_also_very_long
JWT_REFRESH_EXPIRES_IN=7d

# Encryption (AES-256 — must be 32 chars)
ENCRYPTION_KEY=change_this_32_char_encryption_key!!

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# MFA (TOTP)
MFA_ISSUER=AribaEnterpriseAI

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Monitoring
LOG_LEVEL=debug
CORRELATION_ID_HEADER=x-correlation-id
